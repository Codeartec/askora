# Database
DB_USER=askora
DB_PASSWORD=askora_secret
DATABASE_URL=postgresql://askora:askora_secret@localhost:5432/askora

# Auth
JWT_SECRET=change-me-to-a-random-secret
# Duración del access token JWT (formato `jsonwebtoken`, ej: 15m, 24h, 7d)
# Nota: evita comentarios inline (ej. "86400 # ...") porque algunas plataformas los incluyen como parte del valor.
JWT_EXPIRES_IN=1d
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# LLM
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# Frontend (Vite)
VITE_API_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001
# URL pública del front para QR y links de unión (ngrok, dominio, IP LAN). Si no se define, se usa window.location.origin.
# VITE_PUBLIC_APP_URL=https://tu-tunel.ngrok.io

# Production overrides
API_URL=https://askora.yourdomain.com/api
WS_URL=https://askora.yourdomain.com
